# ===== kinaiauto.com — environment =====
# Public — Supabase project URL and anon (publishable) key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Site URL (used for canonical, sitemap, og:url). Production: https://www.kinaiauto.com
NEXT_PUBLIC_SITE_URL=https://www.kinaiauto.com

# Optional — service role key, only needed for ISR revalidation webhooks or admin endpoints.
# DO NOT expose; never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
