# ===== kinaiauto.com — environment =====

# ---- Public site (browser-exposed) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
NEXT_PUBLIC_SITE_URL=https://www.kinaiauto.com

# ---- Server-only (NEVER prefix with NEXT_PUBLIC_) ----
# Service role key — bypasses RLS. Required by the CMS and ISR webhooks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CMS admin gate (path: /c4m5s6).
# CMS_PASSWORD: shared secret typed into the login form.
# CMS_SESSION_SECRET: 32+ char random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CMS_PASSWORD=change-me
CMS_SESSION_SECRET=replace-with-random-hex-string

# ---- Optional: LLM providers for the CMS extract feature ----
# Set at least ONE. The CMS will only show enabled providers in the dropdown.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
